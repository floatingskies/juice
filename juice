# ═══════════════════════════════════════════════════════════════════════════
# DISTROBOX WRAPPER
# ═══════════════════════════════════════════════════════════════════════════

declare -A DISTROBOX_IMAGES=(
    ["arch"]="archlinux:latest"
    ["debian"]="debian:sid"
    ["ubuntu"]="ubuntu:latest"
    ["fedora"]="fedora:latest"
    ["kali"]="kalilinux/kali-rolling:latest"
)

juice_distrobox_create() {
    local distro="${1:-arch}"
    local name="${2:-${distro}-juice}"
    
    command -v distrobox &>/dev/null || { echo -e "${YELLOW}⚠️  Distrobox not installed${RESET}"; return 1; }
    [[ ! -v "DISTROBOX_IMAGES[${distro}]" ]] && { echo -e "${RED}❌ Unknown distro: ${distro}${RESET}"; return 1; }
    
    echo -e "${CYAN}${BOLD}🐳 Creating Container...${RESET}"
    echo -e "${CYAN}   Name: ${YELLOW}${name}${RESET}"
    echo -e "${CYAN}   Image: ${YELLOW}${DISTROBOX_IMAGES[${distro}]}${RESET}"
    
    brew_animation 3 "Pulling & creating" "${CYAN}"
    
    distrobox-create --name "$name" --image "${DISTROBOX_IMAGES[${distro}]}" 2>&1 && {
        celebrate_success "Container created!"
        echo -e "${GREEN}   Enter: ${YELLOW}juice box-enter ${name}${RESET}"
    } || return 1
}

juice_distrobox_enter() {
    local name="${1:-}"
    command -v distrobox &>/dev/null || { echo -e "${RED}❌ Distrobox not installed${RESET}"; return 1; }
    
    [[ -z "$name" ]] && { distrobox-list; echo -e "${CYAN}Enter name:${RESET}"; read -r name; }
    
    distrobox-enter "$name"
}

juice_distrobox_list() {
    command -v distrobox &>/dev/null || { echo -e "${RED}❌ Distrobox not installed${RESET}"; return 1; }
    echo -e "${CYAN}${BOLD}🐳 Distrobox Containers:${RESET}"
    distrobox-list 2>/dev/null
}

juice_distrobox_remove() {
    local name="$1"
    [[ -z "$name" ]] && { echo -e "${RED}❌ No container name${RESET}"; return 1; }
    command -v distrobox &>/dev/null || { echo -e "${RED}❌ Distrobox not installed${RESET}"; return 1; }
    
    echo -e "${ORANGE}${BOLD}🗑️  Removing: ${YELLOW}${name}${RESET}"
    distrobox-rm --force --name "$name" 2>&1 && echo -e "${GREEN}✅ Removed!${RESET}" || return 1
}

