# Brewing bubbles animation
brew_animation() {
    local duration="${1:-2}"
    local message="${2:-Brewing}"
    local color="${3:-${GREEN}}"
    
    local frames=(
        "   🫧    "
        "  🫧🫧   "
        " 🫧🫧🫧  "
        "🫧🫧🫧🫧 "
        " 🫧🫧🫧  "
        "  🫧🫧   "
        "   🫧    "
    )
    
    local spin=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷')
    
    local elapsed=0
    local frame_idx=0
    local spin_idx=0
    
    while (( elapsed < duration )); do
        local frame="${frames[frame_idx % ${#frames[@]}]}"
        local spinner="${spin[spin_idx % ${#spin[@]}]}"
        
        printf "\r${color}${BOLD}  ${spinner}${RESET} ${color}${message}... ${frame}${RESET}   "
        
        sleep 0.1
        ((elapsed += 1, frame_idx++, spin_idx++))
    done
    
    printf "\r"
}

# Success celebration animation
celebrate_success() {
    local message="$1"
    
    echo -e "${GREEN}${BOLD}"
    echo "  ╭──────────────────────────────╮"
    echo "  │  🎉 ${message} 🎉  │"
    echo "  ╰──────────────────────────────╯"
    echo -e "${RESET}"
    
    # Confetti effect
    local confetti=('🎊' '✨' '🌟' '💫' '⭐' '🍋' '🍊')
    for i in {1..5}; do
        local idx=$((RANDOM % ${#confetti[@]}))
        printf "${GREEN}${confetti[idx]}${RESET} "
        sleep 0.05
    done
    echo ""
}

# Progress bar with juice filling
juice_progress() {
    local current="$1"
    local total="$2"
    local message="$3"
    
    local width=40
    local percent=$((current * 100 / total))
    local filled=$((current * width / total))
    local empty=$((width - filled))
    
    printf "\r${BLUE}${BOLD}  🧃 ${message}: ${RESET}"
    printf "${GREEN}"
    printf '█%.0s' $(seq 1 $filled 2>/dev/null) || true
    printf "${DIM}"
    printf '░%.0s' $(seq 1 $empty 2>/dev/null) || true
    printf "${RESET} ${YELLOW}${BOLD}${percent}%%${RESET}   "
}

