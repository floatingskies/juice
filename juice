# DISTROBOX WRAPPER
# ═══════════════════════════════════════════════════════════════════════════

declare -A DISTROBOX_IMAGES=(
    ["arch"]="archlinux:latest"
    ["debian"]="debian:sid"
    ["ubuntu"]="ubuntu:latest"
    ["fedora"]="fedora:latest"
    ["kali"]="kalilinux/kali-rolling:latest"
)

juice_distrobox_create() {
    local distro="${1:-arch}"
    local name="${2:-${distro}-juice}"
    
    if ! command -v distrobox &>/dev/null; then
        echo -e "${YELLOW}⚠️  Distrobox is not installed.${RESET}"
        echo -e "${CYAN}   Install with: ${GREEN}juice install distrobox${RESET}"
        return 1
    fi
    
    if [[ ! -v "DISTROBOX_IMAGES[${distro}]" ]]; then
        echo -e "${RED}❌ Unknown distro: ${distro}${RESET}"
        echo -e "${YELLOW}   Available: arch, debian, ubuntu, fedora, kali${RESET}"
        return 1
    fi
    
    local image="${DISTROBOX_IMAGES[${distro}]}"
    
    echo -e "${CYAN}${BOLD}🐳 Creating Distrobox Container...${RESET}"
    echo -e "${CYAN}   Name: ${YELLOW}${name}${RESET}"
    echo -e "${CYAN}   Image: ${YELLOW}${image}${RESET}"
    echo ""
    
    brew_animation 3 "Pulling & creating container" "${CYAN}"
    
    if distrobox-create --name "$name" --image "$image" 2>&1; then
        celebrate_success "Container created!"
        echo -e "${GREEN}   Enter with: ${YELLOW}juice box-enter ${name}${RESET}"
    else
        echo -e "${RED}❌ Container creation failed${RESET}"
        return 1
    fi
}

juice_distrobox_enter() {
    local name="${1:-}"
    
    if ! command -v distrobox &>/dev/null; then
        echo -e "${RED}❌ Distrobox is not installed${RESET}"
        return 1
    fi
    
    if [[ -z "$name" ]]; then
        echo -e "${YELLOW}📋 Available containers:${RESET}"
        distrobox-list 2>/dev/null
        echo ""
        echo -e "${CYAN}Enter container name:${RESET}"
        read -r name
    fi
    
    echo -e "${CYAN}${BOLD}🐳 Entering container: ${YELLOW}${name}${RESET}"
    echo ""
    
    distrobox-enter "$name"
}

juice_distrobox_list() {
    if ! command -v distrobox &>/dev/null; then
        echo -e "${RED}❌ Distrobox is not installed${RESET}"
        return 1
    fi
    
    echo -e "${CYAN}${BOLD}🐳 Distrobox Containers:${RESET}"
    echo -e "${BLUE}────────────────────────────────────────${RESET}"
    
    distrobox-list 2>/dev/null
}

juice_distrobox_remove() {
    local name="$1"
    
    if [[ -z "$name" ]]; then
        echo -e "${RED}❌ No container name specified${RESET}"
        return 1
    fi
    
    if ! command -v distrobox &>/dev/null; then
        echo -e "${RED}❌ Distrobox is not installed${RESET}"
        return 1
    fi
    
    echo -e "${ORANGE}${BOLD}🗑️  Removing Container: ${YELLOW}${name}${RESET}"
    
    brew_animation 2 "Destroying container" "${ORANGE}"
    
    if distrobox-rm --force --name "$name" 2>&1; then
        echo -e "${GREEN}✅ Container removed!${RESET}"
    else
        echo -e "${RED}❌ Removal failed${RESET}"
        return 1
    fi
}

juice_distrobox_install() {
    local container="$1"; shift
    local packages=("$@")
    
    if [[ -z "$container" ]]; then
        echo -e "${RED}❌ No container specified${RESET}"
        return 1
    fi
    
    if [[ ${#packages[@]} -eq 0 ]]; then
        echo -e "${RED}❌ No packages specified${RESET}"
        return 1
    fi
    
    if ! command -v distrobox &>/dev/null; then
        echo -e "${RED}❌ Distrobox is not installed${RESET}"
        return 1
    fi
    
    echo -e "${CYAN}${BOLD}📦 Installing in Container: ${YELLOW}${container}${RESET}"
    echo -e "${CYAN}   Packages: ${YELLOW}${packages[*]}${RESET}"
    echo ""
    
    brew_animation 2 "Installing in container" "${CYAN}"
    
    # Detect package manager in container
    local pkg_manager
    pkg_manager=$(distrobox-enter "$container" -- which apt pacman dnf 2>/dev/null | head -1)
    
    local install_cmd
    case "$pkg_manager" in
        */apt)    install_cmd="apt install -y" ;;
        */pacman) install_cmd="pacman -S --noconfirm" ;;
        */dnf)    install_cmd="dnf install -y" ;;
        *)
            echo -e "${YELLOW}⚠️  Could not detect package manager, using apt${RESET}"
            install_cmd="apt install -y"
            ;;
    esac
    
    if distrobox-enter "$container" -- $install_cmd "${packages[@]}" 2>&1; then
        celebrate_success "Installed in container!"
    else
        echo -e "${RED}❌ Installation failed${RESET}"
        return 1
    fi
}

# ═══════════════════════════════════════════════════════════════════════════
# QUICK ACTIONS
# ═══════════════════════════════════════════════════════════════════════════

juice_refresh_all() {
    echo -e "${GREEN}${BOLD}🔄 Refreshing Everything!${RESET}"
    echo -e "${BLUE}════════════════════════════════════════${RESET}"
    echo ""
    
    # Native update
    echo -e "${GREEN}📦 Updating native packages...${RESET}"
    juice_update
    
    echo ""
    
    # Flatpak update
    if command -v flatpak &>/dev/null; then
        echo -e "${BLUE}📦 Updating Flatpaks...${RESET}"
        juice_flatpak_update
        echo ""
    fi
    
    # Snap update
    if command -v snap &>/dev/null; then
        echo -e "${MAGENTA}📦 Updating Snaps...${RESET}"
        juice_snap_update
        echo ""
    fi
    
    celebrate_success "Everything is fresh!"
}

juice_clean() {
    echo -e "${YELLOW}${BOLD}🧹 Cleaning Up...${RESET}"
    echo ""
    
    brew_animation 2 "Sweeping cache" "${YELLOW}"
    
    echo -e "${BLUE}────────────────────────────────────────${RESET}"
    
    case "$JUICE_PM" in
        pacman)
            echo -e "${CYAN}Cleaning pacman cache...${RESET}"
            sudo pacman -Sc --noconfirm 2>/dev/null || true
            
            echo -e "${CYAN}Removing orphan packages...${RESET}"
            local orphans=$(pacman -Qtdq 2>/dev/null)
            if [[ -n "$orphans" ]]; then
                sudo pacman -Rns $orphans --noconfirm 2>/dev/null || true
            else
                echo -e "${DIM}No orphans found${RESET}"
            fi
            ;;
        apt)
            echo -e "${CYAN}Cleaning apt cache...${RESET}"
            sudo apt autoremove -y 2>/dev/null || true
            sudo apt autoclean 2>/dev/null || true
            ;;
        dnf)
            echo -e "${CYAN}Cleaning dnf cache...${RESET}"
            sudo dnf autoremove -y 2>/dev/null || true
            sudo dnf clean all 2>/dev/null || true
            ;;
    esac
    
    # Clean flatpak
    if command -v flatpak &>/dev/null; then
        echo -e "${CYAN}Cleaning Flatpak unused data...${RESET}"
        flatpak uninstall --unused -y 2>/dev/null || true
    fi
    
    echo -e "${BLUE}────────────────────────────────────────${RESET}"
    echo -e "${GREEN}✅ System cleaned!${RESET}"
}

juice_doctor() {
    echo -e "${BLUE}${BOLD}🏥 System Health Check${RESET}"
    echo -e "${BLUE}════════════════════════════════════════${RESET}"
    echo ""
    
    # Check native package manager
    echo -e "${GREEN}📦 Native (${JUICE_PM^^}):${RESET}"
    case "$JUICE_PM" in
        pacman)
            echo -e "   ${GREEN}✓${RESET} pacman available"
            local pkg_count=$(pacman -Q 2>/dev/null | wc -l)
            echo -e "   ${CYAN}  ${pkg_count} packages installed${RESET}"
            ;;
        apt)
            echo -e "   ${GREEN}✓${RESET} apt available"
            local pkg_count=$(dpkg -l 2>/dev/null | tail -n +6 | wc -l)
            echo -e "   ${CYAN}  ${pkg_count} packages installed${RESET}"
            ;;
        dnf)
            echo -e "   ${GREEN}✓${RESET} dnf available"
            local pkg_count=$(dnf list installed 2>/dev/null | tail -n +2 | wc -l)
            echo -e "   ${CYAN}  ${pkg_count} packages installed${RESET}"
            ;;
        *)
            echo -e "   ${RED}✗ No supported package manager${RESET}"
            ;;
    esac
    
    # Check flatpak
    echo -e "${BLUE}📦 Flatpak:${RESET}"
    if command -v flatpak &>/dev/null; then
        echo -e "   ${GREEN}✓${RESET} flatpak installed"
        local flat_count=$(flatpak list --app 2>/dev/null | wc -l)
        echo -e "   ${CYAN}  ${flat_count} flatpaks installed${RESET}"
    else
        echo -e "   ${YELLOW}○${RESET} flatpak not installed"
    fi
    
    # Check snap
    echo -e "${MAGENTA}📦 Snap:${RESET}"
    if command -v snap &>/dev/null; then
        echo -e "   ${GREEN}✓${RESET} snap installed"
        local snap_count=$(snap list 2>/dev/null | tail -n +2 | wc -l)
        echo -e "   ${CYAN}  ${snap_count} snaps installed${RESET}"
    else
        echo -e "   ${YELLOW}○${RESET} snap not installed"
    fi
    
    # Check distrobox
    echo -e "${CYAN}📦 Distrobox:${RESET}"
    if command -v distrobox &>/dev/null; then
        echo -e "   ${GREEN}✓${RESET} distrobox installed"
        local box_count=$(distrobox-list 2>/dev/null | tail -n +2 | wc -l)
        echo -e "   ${CYAN}  ${box_count} containers${RESET}"
    else
        echo -e "   ${YELLOW}○${RESET} distrobox not installed"
    fi
    
    echo ""
    echo -e "${GREEN}${BOLD}✅ Health check complete!${RESET}"
}

# ═══════════════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════════════

main() {
    juice_init
    
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi
    
    local command="$1"; shift
    
    case "$command" in
        # Universal native commands
        install|-S)         juice_install "$@" ;;
        remove|-R)          juice_remove "$@" ;;
        update|-Syu)        juice_update ;;
        search|-Ss)         juice_search "$@" ;;
        info|-Si)           juice_info "$@" ;;
        list|-Q)            juice_list ;;
        
        # Flatpak
        flat-install|fi)    juice_flatpak_install "$@" ;;
        flat-remove|fr)     juice_flatpak_remove "$@" ;;
        flat-update|fu)     juice_flatpak_update ;;
        flat-search|fs)     juice_flatpak_search "$@" ;;
        flat-list|fl)       juice_flatpak_list ;;
        
        # Snap
        snap-install|si)    juice_snap_install "$@" ;;
        snap-remove|sr)     juice_snap_remove "$@" ;;
        snap-update|su)     juice_snap_update ;;
        snap-search|ss)     juice_snap_search "$@" ;;
        snap-list|sl)       juice_snap_list ;;
        
        # Distrobox
        box-create|bc)      juice_distrobox_create "$@" ;;
        box-enter|be)       juice_distrobox_enter "$@" ;;
        box-list|bl)        juice_distrobox_list ;;
        box-remove|br)      juice_distrobox_remove "$@" ;;
        box-install|bi)     juice_distrobox_install "$@" ;;
        
        # Quick actions
        refresh)            juice_refresh_all ;;
        clean)              juice_clean ;;
        doctor)             juice_doctor ;;
        
        # Meta
        help|-h|--help)     show_help ;;
        version|-v)         echo -e "${GREEN}${BOLD}Juice v${JUICE_VERSION}${RESET}" ;;
        
        *)
            echo -e "${RED}❌ Unknown command: ${command}${RESET}"
            echo -e "${YELLOW}   Run ${GREEN}juice help${YELLOW} for usage.${RESET}"
            exit 1
            ;;
    esac
}

main "$@"
