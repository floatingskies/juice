# UNIVERSAL INSTALL
juice_install() {
    local packages=("$@")
    
    if [[ ${#packages[@]} -eq 0 ]]; then
        echo -e "${RED}❌ No packages specified${RESET}"
        return 1
    fi
    
    case "$JUICE_PM" in
        pacman) juice_pacman_install "${packages[@]}" ;;
        apt)    juice_apt_install "${packages[@]}" ;;
        dnf)    juice_dnf_install "${packages[@]}" ;;
        *)
            echo -e "${RED}❌ No supported package manager found!${RESET}"
            echo -e "${YELLOW}   Supported: pacman, apt, dnf${RESET}"
            return 1
            ;;
    esac
}

