juice_init() {
    mkdir -p "${JUICE_CONFIG_DIR}" "${JUICE_CACHE_DIR}"
    touch "${JUICE_LOG_FILE}"
}

log() {
    local level="$1"
    shift
    local message="$*"
    local timestamp
    timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[${timestamp}] [${level}] ${message}" >> "${JUICE_LOG_FILE}"
}

