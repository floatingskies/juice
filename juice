check_root() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${YELLOW}⚠️  This action requires root privileges${RESET}"
        echo -e "${CYAN}   Running with sudo...${RESET}"
        exec sudo "$0" "$@"
    fi
}

check_pacman() {
    if ! command -v pacman &>/dev/null; then
        echo -e "${RED}❌ Error: pacman not found!${RESET}"
        echo -e "${YELLOW}   Juice requires an Arch-based distribution.${RESET}"
        exit 1
    fi
}

check_flatpak() {
    if ! command -v flatpak &>/dev/null; then
        echo -e "${YELLOW}⚠️  Flatpak is not installed.${RESET}"
        echo -e "${CYAN}   Would you like to install it? [y/N]${RESET}"
        read -r response
        if [[ "$response" =~ ^[Yy]$ ]]; then
            juice_pacman_install flatpak
            flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
        else
            return 1
        fi
    fi
}

check_snap() {
    if ! command -v snap &>/dev/null; then
        echo -e "${YELLOW}⚠️  Snap is not installed.${RESET}"
        echo -e "${CYAN}   Would you like to install it? [y/N]${RESET}"
        read -r response
        if [[ "$response" =~ ^[Yy]$ ]]; then
            juice_pacman_install snapd
            sudo systemctl enable --now snapd.socket
        else
            return 1
        fi
    fi
}

check_distrobox() {
    if ! command -v distrobox &>/dev/null; then
        echo -e "${YELLOW}⚠️  Distrobox is not installed.${RESET}"
        echo -e "${CYAN}   Would you like to install it? [y/N]${RESET}"
        read -r response
        if [[ "$response" =~ ^[Yy]$ ]]; then
            juice_pacman_install distrobox podman
        else
            return 1
        fi
    fi
}

