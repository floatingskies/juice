# AUR HELPER BACKEND (YAY/PARU)
# ═══════════════════════════════════════════════════════════════════════════

juice_aur_install() {
    local packages=("$@")
    
    if [[ ${#packages[@]} -eq 0 ]]; then
        echo -e "${RED}❌ No packages specified${RESET}"
        return 1
    fi
    
    if [[ -z "$JUICE_AUR" ]]; then
        echo -e "${YELLOW}⚠️  No AUR helper found!${RESET}"
        echo -e "${CYAN}   Install one with:${RESET}"
        echo -e "   ${GREEN}juice install yay${RESET}  ${DIM}# or paru${RESET}"
        return 1
    fi
    
    echo -e "${PURPLE}${BOLD}📦 Installing from AUR (${JUICE_AUR})...${RESET}"
    echo -e "${CYAN}   Packages: ${YELLOW}${packages[*]}${RESET}"
    echo ""
    
    brew_animation 2 "Brewing AUR juice" "${PURPLE}"
    
    echo -e "${BLUE}────────────────────────────────────────${RESET}"
    
    local cmd
    [[ "$JUICE_AUR" == "yay" ]] && cmd="yay -S --noconfirm" || cmd="paru -S --noconfirm"
    
    if $cmd "${packages[@]}" 2>&1; then
        echo -e "${BLUE}────────────────────────────────────────${RESET}"
        celebrate_success "AUR package installed!"
        log "INFO" "Installed AUR packages: ${packages[*]}"
    else
        echo -e "${BLUE}────────────────────────────────────────${RESET}"
        echo -e "${RED}❌ Installation failed${RESET}"
        return 1
    fi
}

juice_aur_remove() {
    local packages=("$@")
    
    if [[ ${#packages[@]} -eq 0 ]]; then
        echo -e "${RED}❌ No packages specified${RESET}"
        return 1
    fi
    
    if [[ -z "$JUICE_AUR" ]]; then
        echo -e "${RED}❌ No AUR helper found${RESET}"
        return 1
    fi
    
    echo -e "${ORANGE}${BOLD}🗑️  Removing AUR packages...${RESET}"
    echo -e "${CYAN}   Packages: ${YELLOW}${packages[*]}${RESET}"
    echo ""
    
    brew_animation 2 "Cleaning up" "${ORANGE}"
    
    local cmd
    [[ "$JUICE_AUR" == "yay" ]] && cmd="yay -Rns --noconfirm" || cmd="paru -Rns --noconfirm"
    
    if $cmd "${packages[@]}" 2>&1; then
        echo -e "${GREEN}✅ AUR packages removed!${RESET}"
        log "INFO" "Removed AUR packages: ${packages[*]}"
    else
        echo -e "${RED}❌ Removal failed${RESET}"
        return 1
    fi
}

juice_aur_update() {
    if [[ -z "$JUICE_AUR" ]]; then
        echo -e "${RED}❌ No AUR helper found${RESET}"
        return 1
    fi
    
    echo -e "${PURPLE}${BOLD}🔄 Updating AUR Packages...${RESET}"
    echo ""
    
    brew_animation 2 "Brewing updates" "${CYAN}"
    
    echo -e "${BLUE}────────────────────────────────────────${RESET}"
    
    local cmd
    [[ "$JUICE_AUR" == "yay" ]] && cmd="yay -Syu --noconfirm" || cmd="paru -Syu --noconfirm"
    
    if $cmd 2>&1; then
        echo -e "${BLUE}────────────────────────────────────────${RESET}"
        celebrate_success "AUR packages updated!"
    else
        echo -e "${RED}❌ Update failed${RESET}"
        return 1
    fi
}

juice_aur_search() {
    local query="$1"
    [[ -z "$query" ]] && { echo -e "${RED}❌ No search query${RESET}"; return 1; }
    
    if [[ -z "$JUICE_AUR" ]]; then
        echo -e "${RED}❌ No AUR helper found${RESET}"
        return 1
    fi
    
    echo -e "${PURPLE}${BOLD}🔍 Searching AUR for: ${YELLOW}${query}${RESET}"
    echo ""
    
    local cmd
    [[ "$JUICE_AUR" == "yay" ]] && cmd="yay -Ss" || cmd="paru -Ss"
    
    $cmd "$query" 2>/dev/null | head -50
}

juice_aur_info() {
    local package="$1"
    [[ -z "$package" ]] && { echo -e "${RED}❌ No package specified${RESET}"; return 1; }
    
    if [[ -z "$JUICE_AUR" ]]; then
