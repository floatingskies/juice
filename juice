# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
readonly JUICE_VERSION="1.0.0"
readonly JUICE_CONFIG_DIR="${HOME}/.config/juice"
readonly JUICE_CACHE_DIR="${HOME}/.cache/juice"
readonly JUICE_LOG_FILE="${JUICE_CACHE_DIR}/juice.log"

# Detected package manager
JUICE_PM=""

# ═══════════════════════════════════════════════════════════════════════════
# UTILITY FUNCTIONS
# ═══════════════════════════════════════════════════════════════════════════

juice_init() {
    mkdir -p "${JUICE_CONFIG_DIR}" "${JUICE_CACHE_DIR}" 2>/dev/null || true
    touch "${JUICE_LOG_FILE}" 2>/dev/null || true
    detect_package_manager
}

log() {
    local level="$1"; shift
    local message="$*"
    local timestamp
    timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[${timestamp}] [${level}] ${message}" >> "${JUICE_LOG_FILE}" 2>/dev/null || true
}

# Detect available package manager
detect_package_manager() {
    if command -v pacman &>/dev/null; then
        JUICE_PM="pacman"
    elif command -v apt &>/dev/null; then
        JUICE_PM="apt"
    elif command -v dnf &>/dev/null; then
        JUICE_PM="dnf"
    else
        JUICE_PM="unknown"
    fi
}

# ═══════════════════════════════════════════════════════════════════════════
# BREWING ANIMATION SYSTEM - The Magic! ✨
# ═══════════════════════════════════════════════════════════════════════════

brew_animation() {
    local duration="${1:-2}"
    local message="${2:-Brewing}"
    local color="${3:-${GREEN}}"
    
    local frame_idx=0
    local spin_idx=0
    local count=0
    local max_iterations=$((duration * 10))
    
    while [[ $count -lt $max_iterations ]]; do
        local bubble_frame
        case $((frame_idx % 7)) in
            0) bubble_frame="   🫧    " ;;
            1) bubble_frame="  🫧🫧   " ;;
            2) bubble_frame=" 🫧🫧🫧  " ;;
            3) bubble_frame="🫧🫧🫧🫧 " ;;
            4) bubble_frame=" 🫧🫧🫧  " ;;
            5) bubble_frame="  🫧🫧   " ;;
            6) bubble_frame="   🫧    " ;;
        esac
        
        local spinner
        case $((spin_idx % 8)) in
            0) spinner='⣾' ;; 1) spinner='⣽' ;; 2) spinner='⣻' ;; 3) spinner='⢿' ;;
            4) spinner='⡿' ;; 5) spinner='⣟' ;; 6) spinner='⣯' ;; 7) spinner='⣷' ;;
        esac
        
        printf "\r${color}${BOLD}  ${spinner}${RESET} ${color}${message}... ${bubble_frame}${RESET}   "
        
        sleep 0.1
        ((frame_idx++, spin_idx++, count++))
    done
    
    printf "\r%80s\r" ""
}

celebrate_success() {
    local message="$1"
    local len=${#message}
    local padding=$((20 - len))
    local left_pad=$((padding / 2))
    local right_pad=$((padding - left_pad))
    
    echo -e "${GREEN}${BOLD}"
    echo "  ╭──────────────────────────────────╮"
    printf "  │"
    for ((i=0; i<left_pad; i++)); do printf " "; done
    printf "🎉 %s 🎉" "$message"
    for ((i=0; i<right_pad; i++)); do printf " "; done
    printf "│\n"
    echo "  ╰──────────────────────────────────╯"
    echo -e "${RESET}"
    
    # Confetti
    local confetti=('🎊' '✨' '🌟' '💫' '⭐' '🍋' '🍊')
    for i in {1..7}; do
        printf "${GREEN}${confetti[$((RANDOM % 7))]}${RESET} "
    done
    echo ""
}

