    echo -e "${GREEN}📦 Updating native packages...${RESET}"
    juice_update
    
    [[ -n "$JUICE_AUR" ]] && { echo ""; echo -e "${PURPLE}📦 Updating AUR packages...${RESET}"; juice_aur_update; }
    
    command -v flatpak &>/dev/null && { echo ""; echo -e "${BLUE}📦 Updating Flatpaks...${RESET}"; juice_flatpak_update; }
    
    command -v snap &>/dev/null && { echo ""; echo -e "${MAGENTA}📦 Updating Snaps...${RESET}"; juice_snap_update; }
    
    celebrate_success "Everything is fresh!"
}

juice_clean() {
    echo -e "${YELLOW}${BOLD}🧹 Cleaning Up...${RESET}"
    brew_animation 2 "Sweeping cache" "${YELLOW}"
    
    case "$JUICE_PM" in
        pacman)
            echo -e "${CYAN}Cleaning pacman cache...${RESET}"
            sudo pacman -Sc --noconfirm 2>/dev/null || true
            echo -e "${CYAN}Removing orphans...${RESET}"
            local orphans=$(pacman -Qtdq 2>/dev/null)
            [[ -n "$orphans" ]] && sudo pacman -Rns $orphans --noconfirm || echo -e "${DIM}No orphans${RESET}"
            ;;
        apt)
            sudo apt autoremove -y && sudo apt autoclean
            ;;
        dnf)
            sudo dnf autoremove -y && sudo dnf clean all
            ;;
    esac
    
    command -v flatpak &>/dev/null && { echo -e "${CYAN}Cleaning Flatpak...${RESET}"; flatpak uninstall --unused -y 2>/dev/null || true; }
    
    echo -e "${GREEN}✅ System cleaned!${RESET}"
}

juice_doctor() {
    echo -e "${BLUE}${BOLD}🏥 System Health Check${RESET}"
    echo -e "${BLUE}════════════════════════════════════════${RESET}"
    
    echo -e "${GREEN}📦 Native (${JUICE_PM^^}):${RESET}"
    if [[ "$JUICE_PM" != "unknown" ]]; then
        echo -e "   ${GREEN}✓${RESET} ${JUICE_PM} available"
        [[ "$JUICE_PM" == "pacman" ]] && echo -e "   ${CYAN}  $(pacman -Q | wc -l) packages${RESET}"
    else
        echo -e "   ${RED}✗ No package manager${RESET}"
    fi
    
    echo -e "${PURPLE}📦 AUR Helper:${RESET}"
    [[ -n "$JUICE_AUR" ]] && echo -e "   ${GREEN}✓${RESET} ${JUICE_AUR}" || echo -e "   ${YELLOW}○${RESET} Not installed"
    
    echo -e "${BLUE}📦 Flatpak:${RESET}"
    command -v flatpak &>/dev/null && echo -e "   ${GREEN}✓${RESET} $(flatpak list --app | wc -l) apps" || echo -e "   ${YELLOW}○${RESET} Not installed"
    
    echo -e "${MAGENTA}📦 Snap:${RESET}"
    command -v snap &>/dev/null && echo -e "   ${GREEN}✓${RESET} $(snap list 2>/dev/null | tail -n +2 | wc -l) snaps" || echo -e "   ${YELLOW}○${RESET} Not installed"
    
    echo -e "${CYAN}📦 Distrobox:${RESET}"
    command -v distrobox &>/dev/null && echo -e "   ${GREEN}✓${RESET} $(distrobox-list 2>/dev/null | tail -n +2 | wc -l) containers" || echo -e "   ${YELLOW}○${RESET} Not installed"
    
    echo ""
    echo -e "${GREEN}${BOLD}✅ Health check complete!${RESET}"
}

# ═══════════════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════════════

main() {
    juice_init
    
    [[ $# -eq 0 ]] && { show_help; exit 0; }
    
    local command="$1"; shift
    
    case "$command" in
        # Native
        install|-S)         juice_install "$@" ;;
        remove|-R)          juice_remove "$@" ;;
        update|-Syu)        juice_update ;;
        search|-Ss)         juice_search "$@" ;;
        info|-Si)           juice_info "$@" ;;
        list|-Q)            juice_list ;;
        
        # AUR (yay/paru)
        aur-install|ai)     juice_aur_install "$@" ;;
        aur-remove|ar)      juice_aur_remove "$@" ;;
        aur-update|au)      juice_aur_update ;;
        aur-search|as)      juice_aur_search "$@" ;;
        aur-info|aii)       juice_aur_info "$@" ;;
        
        # Flatpak
        flat-install|fi)    juice_flatpak_install "$@" ;;
        flat-remove|fr)     juice_flatpak_remove "$@" ;;
        flat-update|fu)     juice_flatpak_update ;;
        flat-search|fs)     juice_flatpak_search "$@" ;;
        flat-list|fl)       juice_flatpak_list ;;
        
        # Snap
        snap-install|si)    juice_snap_install "$@" ;;
        snap-remove|sr)     juice_snap_remove "$@" ;;
        snap-update|su)     juice_snap_update ;;
        snap-search|ss)     juice_snap_search "$@" ;;
        snap-list|sl)       juice_snap_list ;;
        
        # Distrobox
        box-create|bc)      juice_distrobox_create "$@" ;;
        box-enter|be)       juice_distrobox_enter "$@" ;;
        box-list|bl)        juice_distrobox_list ;;
        box-remove|br)      juice_distrobox_remove "$@" ;;
        
        # Quick actions
        refresh)            juice_refresh_all ;;
        clean)              juice_clean ;;
        doctor)             juice_doctor ;;
        
        # Meta
        help|-h|--help)     show_help ;;
        version|-v)         echo -e "${GREEN}${BOLD}Juice v${JUICE_VERSION}${RESET}" ;;
        
        *)
            echo -e "${RED}❌ Unknown command: ${command}${RESET}"
            echo -e "${YELLOW}   Run ${GREEN}juice help${YELLOW} for usage.${RESET}"
            exit 1
            ;;
    esac
}

main "$@"
