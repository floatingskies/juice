# ═══════════════════════════════════════════════════════════════════════════

juice_refresh_all() {
    echo -e "${GREEN}${BOLD}🔄 Refreshing Everything!${RESET}"
    echo -e "${BLUE}════════════════════════════════════════${RESET}"
    echo ""
    
    # Pacman update
    echo -e "${GREEN}📦 Updating Pacman packages...${RESET}"
    juice_pacman_update
    
    echo ""
    
    # Flatpak update
    if command -v flatpak &>/dev/null; then
        echo -e "${BLUE}📦 Updating Flatpaks...${RESET}"
        juice_flatpak_update
        echo ""
    fi
    
    # Snap update
    if command -v snap &>/dev/null; then
        echo -e "${MAGENTA}📦 Updating Snaps...${RESET}"
        juice_snap_update
        echo ""
    fi
    
    celebrate_success "Everything is fresh!"
}

juice_clean() {
    echo -e "${YELLOW}${BOLD}🧹 Cleaning Up...${RESET}"
    echo ""
    
    brew_animation 2 "Sweeping cache" "${YELLOW}"
    
    echo -e "${BLUE}────────────────────────────────────────${RESET}"
    
    # Clean pacman cache
    echo -e "${CYAN}Cleaning pacman cache...${RESET}"
    sudo pacman -Sc --noconfirm 2>/dev/null || true
    
    # Remove orphans
    echo -e "${CYAN}Removing orphan packages...${RESET}"
    sudo pacman -Rns $(pacman -Qtdq) --noconfirm 2>/dev/null || echo -e "${DIM}No orphans found${RESET}"
    
    # Clean flatpak
    if command -v flatpak &>/dev/null; then
        echo -e "${CYAN}Cleaning Flatpak unused data...${RESET}"
        flatpak uninstall --unused -y 2>/dev/null || true
    fi
    
    echo -e "${BLUE}────────────────────────────────────────${RESET}"
    echo -e "${GREEN}✅ System cleaned!${RESET}"
}

juice_doctor() {
    echo -e "${BLUE}${BOLD}🏥 System Health Check${RESET}"
    echo -e "${BLUE}════════════════════════════════════════${RESET}"
    echo ""
    
    # Check pacman
    echo -e "${GREEN}📦 Pacman:${RESET}"
    if command -v pacman &>/dev/null; then
        echo -e "   ${GREEN}✓${RESET} pacman installed"
        local pkg_count
        pkg_count=$(pacman -Q | wc -l)
        echo -e "   ${CYAN}  ${pkg_count} packages installed${RESET}"
    else
        echo -e "   ${RED}✗ pacman not found${RESET}"
    fi
    
    # Check flatpak
    echo -e "${BLUE}📦 Flatpak:${RESET}"
    if command -v flatpak &>/dev/null; then
        echo -e "   ${GREEN}✓${RESET} flatpak installed"
        local flat_count
        flat_count=$(flatpak list --app | wc -l)
        echo -e "   ${CYAN}  ${flat_count} flatpaks installed${RESET}"
    else
        echo -e "   ${YELLOW}○${RESET} flatpak not installed"
    fi
    
    # Check snap
    echo -e "${MAGENTA}📦 Snap:${RESET}"
    if command -v snap &>/dev/null; then
        echo -e "   ${GREEN}✓${RESET} snap installed"
        local snap_count
        snap_count=$(snap list 2>/dev/null | wc -l)
        echo -e "   ${CYAN}  $((snap_count - 1)) snaps installed${RESET}"
    else
        echo -e "   ${YELLOW}○${RESET} snap not installed"
    fi
    
    # Check distrobox
    echo -e "${CYAN}📦 Distrobox:${RESET}"
    if command -v distrobox &>/dev/null; then
        echo -e "   ${GREEN}✓${RESET} distrobox installed"
        local box_count
        box_count=$(distrobox-list 2>/dev/null | grep -c "NAME" || echo "0")
        echo -e "   ${CYAN}  ${box_count} containers${RESET}"
    else
        echo -e "   ${YELLOW}○${RESET} distrobox not installed"
    fi
    
    echo ""
    echo -e "${BLUE}════════════════════════════════════════${RESET}"
    
    # Check for updates
    echo -e "${YELLOW}🔍 Checking for updates...${RESET}"
    if pacman -Qu &>/dev/null | grep -q .; then
        local updates
        updates=$(pacman -Qu | wc -l)
        echo -e "   ${ORANGE}⚠${RESET} ${updates} updates available"
        echo -e "   ${CYAN}  Run ${YELLOW}juice update${CYAN} to update${RESET}"
    else
        echo -e "   ${GREEN}✓${RESET} System is up to date!"
    fi
    
    echo ""
    echo -e "${GREEN}${BOLD}✅ Health check complete!${RESET}"
}

# ═══════════════════════════════════════════════════════════════════════════
# MAIN ENTRY POINT - Let's Go! 🚀
# ═══════════════════════════════════════════════════════════════════════════

main() {
    juice_init
    
    # No arguments - show help
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi
    
    local command="$1"
    shift
    
    case "$command" in
        # Pacman commands
        install|-S|-Si)
            juice_pacman_install "$@"
            ;;
        remove|-R|-Rs|-Rns)
            juice_pacman_remove "$@"
            ;;
        update|-Syu|upgrade)
            juice_pacman_update
            ;;
        search|-Ss)
            juice_pacman_search "$@"
            ;;
        info|-Qi)
            juice_pacman_info "$@"
            ;;
        list|-Q|-Qe)
            juice_pacman_list
            ;;
        
        # Flatpak commands
        flat-install|fi)
            juice_flatpak_install "$@"
            ;;
        flat-remove|fr)
            juice_flatpak_remove "$@"
            ;;
        flat-update|fu)
            juice_flatpak_update
            ;;
        flat-search|fs)
            juice_flatpak_search "$@"
            ;;
        flat-list|fl)
            juice_flatpak_list
            ;;
        
        # Snap commands
        snap-install|si)
            juice_snap_install "$@"
            ;;
        snap-remove|sr)
            juice_snap_remove "$@"
            ;;
        snap-update|su)
            juice_snap_update
            ;;
        snap-search|ss)
            juice_snap_search "$@"
            ;;
        snap-list|sl)
            juice_snap_list
            ;;
        
        # Distrobox commands
        box-create|bc)
            juice_distrobox_create "$@"
            ;;
        box-enter|be)
            juice_distrobox_enter "$@"
            ;;
        box-list|bl)
            juice_distrobox_list
            ;;
        box-remove|br)
            juice_distrobox_remove "$@"
            ;;
        box-install|bi)
            juice_distrobox_install "$@"
            ;;
        
        # Quick actions
        refresh)
            juice_refresh_all
            ;;
        clean)
            juice_clean
            ;;
        doctor)
            juice_doctor
            ;;
        
        # Meta commands
        help|-h|--help)
            show_help
            ;;
        version|-v|--version)
            show_version
            ;;
        
        # Unknown command
        *)
            echo -e "${RED}❌ Unknown command: ${command}${RESET}"
            echo -e "${YELLOW}   Run ${GREEN}juice help${YELLOW} for usage information.${RESET}"
            exit 1
            ;;
    esac
}

# Run main function
main "$@"
