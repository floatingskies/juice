# PACMAN BACKEND
# ═══════════════════════════════════════════════════════════════════════════

juice_pacman_install() {
    local packages=("$@")
    
    echo -e "${GREEN}${BOLD}📦 Installing with Pacman...${RESET}"
    echo -e "${CYAN}   Packages: ${YELLOW}${packages[*]}${RESET}"
    echo ""
    
    brew_animation 2 "Squeezing fresh juice" "${GREEN}"
    
    echo -e "${BLUE}────────────────────────────────────────${RESET}"
    
    if sudo pacman -S --noconfirm "${packages[@]}" 2>&1; then
        echo -e "${BLUE}────────────────────────────────────────${RESET}"
        celebrate_success "Installed successfully!"
        log "INFO" "Installed packages: ${packages[*]}"
    else
        echo -e "${BLUE}────────────────────────────────────────${RESET}"
        echo -e "${RED}❌ Installation failed${RESET}"
        log "ERROR" "Failed to install: ${packages[*]}"
        return 1
    fi
}

juice_pacman_remove() {
    local packages=("$@")
    
    echo -e "${ORANGE}${BOLD}🗑️  Removing packages...${RESET}"
    echo -e "${CYAN}   Packages: ${YELLOW}${packages[*]}${RESET}"
    echo ""
    
    brew_animation 2 "Cleaning up" "${ORANGE}"
    
    echo -e "${BLUE}────────────────────────────────────────${RESET}"
    
    if sudo pacman -Rns --noconfirm "${packages[@]}" 2>&1; then
        echo -e "${BLUE}────────────────────────────────────────${RESET}"
        echo -e "${GREEN}✅ Packages removed!${RESET}"
        log "INFO" "Removed packages: ${packages[*]}"
    else
        echo -e "${BLUE}────────────────────────────────────────${RESET}"
        echo -e "${RED}❌ Removal failed${RESET}"
        return 1
    fi
}

juice_pacman_update() {
    echo -e "${GREEN}${BOLD}🔄 Updating System...${RESET}"
    echo ""
    
    brew_animation 2 "Refreshing package databases" "${CYAN}"
    
    echo -e "${BLUE}────────────────────────────────────────${RESET}"
    
    if sudo pacman -Syu --noconfirm 2>&1; then
        echo -e "${BLUE}────────────────────────────────────────${RESET}"
        celebrate_success "System updated!"
        log "INFO" "System updated"
    else
        echo -e "${BLUE}────────────────────────────────────────${RESET}"
        echo -e "${RED}❌ Update failed${RESET}"
        return 1
    fi
}

juice_pacman_search() {
    local query="$1"
    
    echo -e "${BLUE}${BOLD}🔍 Searching for: ${YELLOW}${query}${RESET}"
    echo ""
    
    local results
    results=$(pacman -Ss "$query" 2>/dev/null)
    
    if [[ -n "$results" ]]; then
        echo "$results" | while IFS= read -r line; do
            if [[ "$line" =~ ^[a-z] ]]; then
                echo -e "${GREEN}${line}${RESET}"
            else
                echo -e "${DIM}${line}${RESET}"
            fi
        done
    else
        echo -e "${YELLOW}No results found for '${query}'${RESET}"
    fi
}

juice_pacman_info() {
    local package="$1"
    
    echo -e "${BLUE}${BOLD}📋 Package Information: ${YELLOW}${package}${RESET}"
    echo -e "${BLUE}────────────────────────────────────────${RESET}"
    
    pacman -Si "$package" 2>/dev/null || echo -e "${RED}Package not found in repositories${RESET}"
}

juice_pacman_list() {
    echo -e "${GREEN}${BOLD}📦 Installed Packages:${RESET}"
    echo -e "${BLUE}────────────────────────────────────────${RESET}"
    
    pacman -Q 2>/dev/null | while IFS= read -r line; do
        local name="${line%% *}"
        local version="${line##* }"
        echo -e "${GREEN}${name}${RESET} ${DIM}${version}${RESET}"
    done
}

